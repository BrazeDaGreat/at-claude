# Discord bot token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your-bot-token-here

# Comma-separated Discord user IDs allowed to use the bot.
# Leave empty to allow anyone (NOT recommended). Example: 123456789012345678,987654321098765432
ALLOWED_USER_IDS=

# Path to the claude executable. "claude" works if it's on your PATH.
CLAUDE_BIN=claude

# Model to use. Alias ("sonnet", "opus") or full id ("claude-opus-4-8").
# Leave empty to use the claude CLI default. Override per-channel at runtime with `/model <x>`.
CLAUDE_MODEL=

# Effort / reasoning level: low, medium, high, xhigh, max.
# Only applies to models that support it (Sonnet, Opus). Leave empty to use the default.
# Override per-channel at runtime with `/effort <level>`.
CLAUDE_EFFORT=

# Permission mode passed to `claude -p`.
#   bypassPermissions  -> runs all tools without asking (most useful, full power)
#   acceptEdits        -> auto-accepts file edits, asks for other tools (will hang non-interactively)
#   default / plan     -> see `claude --help`
CLAUDE_PERMISSION_MODE=bypassPermissions

# Max time (ms) a single claude run may take before being killed.
CLAUDE_TIMEOUT_MS=600000

# Keep conversation context per Discord channel (true/false).
# When true, follow-up messages in the same channel resume the same Claude session.
PERSIST_SESSIONS=true
